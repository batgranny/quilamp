{
  "name": "quilmp",
  "version": "1.1.0",
  "description": "Winamp clone for macOS",
  "author": "Batgranny",
  "main": "main.js",
  "scripts": {
    "start": "NODE_ENV=production electron .",
    "dev": "vite",
    "build": "vite build && electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "^2.4.7",
    "jsmediatags": "^3.9.7",
    "jszip": "^3.10.1",
    "music-metadata": "^11.12.1"
  },
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.chrisconnolly.quilmp",
    "productName": "Quilamp",
    "mac": {
      "category": "public.app-category.music"
    },
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "icon": "build/icon.png"
  }
}