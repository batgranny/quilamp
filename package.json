{
  "name": "quinamp",
  "version": "1.0.0",
  "description": "Winamp clone for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build": "vite build && electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "electron": "^29.1.5",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.chrisconnolly.quinamp",
    "productName": "Quinamp",
    "mac": {
      "category": "public.app-category.music"
    },
    "directories": {
      "buildResources": "build"
    }
  }
}
